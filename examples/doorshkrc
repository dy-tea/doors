#
# doors hotkey configuration
#

# terminal emulator
alt + Return
	foot

# launcher
alt + space
	rofi -show drun

# close window
alt + shift + q
	doorsctl node --close

# toggle fullscreen
alt + f
	doorsctl node --state fullscreen

# toggle floating
alt + shift + space
	doorsctl node --state floating

# toggle monocle
alt + m
	doorsctl desktop --layout monocle

# window navigation (using brace expansion)
alt + {h,j,k,l}
	doorsctl focus {west,south,north,east}

# window swapping (using brace expansion)
alt + shift + {h,j,k,l}
	doorsctl swap {west,south,north,east}

# cancel preselection
alt + ctrl + space
	doorsctl presel cancel

# rotate
alt + r
	doorsctl rotate clockwise
alt + shift + r
	doorsctl rotate counterclockwise

# flip
alt + {comma,period}
	doorsctl flip {horizontal,vertical}

# resizing tiled windows (using brace expansion)
alt + ctrl + {h,j,k,l}
	doorsctl resize {left,down,up,right}

# floating window interactions (alt + mouse on floating windows)
alt + mouse_left
	doorsctl node interactive_move
alt + mouse_right
	doorsctl node interactive_resize

# desktop switching (1-based index)
# Using brace expansion with range syntax
alt + {1-9}
	doorsctl desktop {1-9}
alt + 0
	doorsctl desktop 10

# send to desktop (1-based index)
alt + shift + {1-9}
	doorsctl node --to-desktop {1-9}
alt + shift + 0
	doorsctl node --to-desktop 10

# send to next/prev desktop
alt + shift + {Right,Left}
	doorsctl send {next,prev}

# quit
alt + shift + Escape
	doorsctl quit

# executed when the system bell is rung
bell
	ffplay -nodisp -autoexit /usr/share/sounds/freedesktop/stereo/bell.oga

# Gesture bindings (touchpad)
gesture swipe:3:left
	doorsctl desktop --focus prev
gesture swipe:3:right
	doorsctl desktop --focus next
gesture pinch:in
	doorsctl node --state fullscreen
gesture pinch:out
	doorsctl node --state fullscreen

# Hot corner bindings
hotcorner topleft
	doorsctl desktop --layout monocle

# Focus submap
# enter submap with alt + shift + f
alt + shift + f -> @focus

# focus with h j k l, exit with escape
@focus
  escape
    @exit
  {h,j,k,l}
    doorsctl focus {west,south,north,east}
