#
# bwm hotkey configuration
#

# terminal emulator
alt + Return
	foot

# launcher
alt + space
	rofi -show drun

# close window
alt + shift + q
	bmsg node --close

# toggle fullscreen
alt + f
	bmsg node --state fullscreen

# toggle floating
alt + shift + space
	bmsg node --state floating

# toggle monocle
alt + m
	bmsg desktop --layout monocle

# window navigation (using brace expansion)
alt + {h,j,k,l}
	bmsg focus {west,south,north,east}

# window swapping (using brace expansion)
alt + shift + {h,j,k,l}
	bmsg swap {west,south,north,east}

# cancel preselection
alt + ctrl + space
	bmsg presel cancel

# rotate
alt + r
	bmsg rotate clockwise
alt + shift + r
	bmsg rotate counterclockwise

# flip
alt + {comma,period}
	bmsg flip {horizontal,vertical}

# resizing tiled windows (using brace expansion)
alt + ctrl + {h,j,k,l}
	bmsg resize {left,down,up,right}

# floating window interactions (alt + mouse on floating windows)
alt + mouse_left
	bmsg node interactive_move
alt + mouse_right
	bmsg node interactive_resize

# desktop switching (1-based index)
# Using brace expansion with range syntax
alt + {1-9}
	bmsg desktop {1-9}
alt + 0
	bmsg desktop 10

# send to desktop (1-based index)
alt + shift + {1-9}
	bmsg node --to-desktop {1-9}
alt + shift + 0
	bmsg node --to-desktop 10

# send to next/prev desktop
alt + shift + {Right,Left}
	bmsg send {next,prev}

# quit
alt + shift + Escape
	bmsg quit

# executed when the system bell is rung
bell
	ffplay -nodisp -autoexit /usr/share/sounds/freedesktop/stereo/bell.oga

# Gesture bindings (touchpad)
gesture swipe:3:left
	bmsg desktop --focus prev
gesture swipe:3:right
	bmsg desktop --focus next
gesture pinch:in
	bmsg node --state fullscreen
gesture pinch:out
	bmsg node --state fullscreen

# Hot corner bindings
hotcorner topleft
	bmsg desktop --layout monocle

# Focus submap
# enter submap with alt + shift + f
alt + shift + f -> @focus

# focus with h j k l, exit with escape
@focus
  escape
    @exit
  {h,j,k,l}
    bmsg focus {west,south,north,east}
